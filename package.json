{
  "name": "RFF",
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json,html,css}\"",
    "format": "prettier \"**/*.{js,jsx,ts,tsx,json,html,css}\" --write",
    "web": "expo start --web",
    "ktlint:format": "cd android && ./gradlew :book-engine:ktlintFormat",
    "ktlint:check": "./android/gradlew -p modules/book-engine/android ktlintCheck"
  },
  "dependencies": {
    "@epubjs-react-native/core": "^1.4.7",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-vector-icons/material-design-icons": "^12.4.0",
    "@react-navigation/drawer": "^7.8.1",
    "@react-navigation/native": "^7.1.28",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "^54.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-status-bar": "~3.0.8",
    "fast-xml-parser": "^5.3.6",
    "nativewind": "latest",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^4.1.2",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-webview": "^13.15.0",
    "react-native-worklets": "0.5.1",
    "react-native-zip-archive": "^7.0.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "babel-plugin-inline-import": "^3.0.0",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "supabase": "^2.76.15",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "main": "node_modules/expo/AppEntry.js",
  "private": true
}
